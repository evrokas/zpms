# Zeus Framework
# Patient Management System site configuration file

# set to 1 to enable php_display_errors
php_display_errors: 1

# set to 1 to enable php_display_startup_errors
php_display_startup_errors: 1


# set to 1 to enable comments in produced .html file (default: 0)
enable_template_comments: 0

# set to 1 to enable cache in produced templates
enable_template_cache: 0

# set to path for cachee (used on when 'enable_template_cache' is set to 1)
template_cache_path: "cache/"

# library path for stored files
libpath: files/

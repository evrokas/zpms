#<IfModule mod_rewrite.c>    
    # <IfModule mod_negotiation.c>
    Options +FollowSymLinks
    Options -Indexes
    # </IfModule>     
#    Loglevel rewrite:trace8
    
    DirectoryIndex index.php

    RewriteEngine On
    # RewriteLogLevel trace8  
#    RewriteBase /apps/zeus-devel/web/

    ErrorDocument 404 error.php

    # File management system rules
    # Block direct access to non-public file zones
    RewriteRule ^files/(private|temp|cache)/ - [F,L]

    # Serve public files directly if they exist
    RewriteCond %{DOCUMENT_ROOT}/../files/public/$1 -f
    RewriteRule ^files/public/(.+)$ ../files/public/$1 [L]

    # Catch-all: route everything else through index.php
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.*)$ index.php?$1 [QSA,L,PT]
    
    




#</IfModule>


{% attach_library('loader-library'); %}
{# {% attach_library('datepicker-library'); %} #}
{# {% attach_library('pikaday-library'); %} #}
{% attach_library('textarea-expandable-library'); %}


<div class="edit-patient">    
    <div class="header">
        <h4>Επεξεργασία στοιχείων ασθενή</h4>
    </div>
    <form action="{{$action}}" method="post">

        {#
            <div class="input-div">
            {% if($action != 'new'): %}
                <p>Patient GUID: {{$patient->getguid()}}
                </p>
            {% endif %}
            </div>
        #}

        <div class="input-div">
            <label for="patient-name">Όνομα ασθενή</label>
            <input type="text" name="patient-name" loader="info-loader" id="" value="{{$patient->getpname()}}" placeholder="όνομα ασθενούς">

            <div class="inline-icons">
                <i class="bx bx-copy" data-copy-text="{{$patient->getpname()}}" onclick0="copyStr('{{$patient->getpname()}}')"></i>
            </div>
        </div>
<!-- 
        <div class="input-div">
            <label for="patient-dob">Ημ/νια Γεννήσεως</label>
            <input type="datetime-local" name="patient-dob" id="" value="{{formatDate($patient->getpdob())}}">
            <input type="text" name="patient-dob" id="datepicker" value="{{$patient->getpdob()}}">
        </div>
    -->
        

        <div class="input-div">
            <label for="patient-dob">Ημ/νια Γεννήσεως</label>
            <!-- <input type="date" name="patient-dob" id="" value="{{formatDate($patient->getpdob())}}"> -->
            <input type="text" name="patient-dob" id="datepicker" value="{{$patient->getpdob()| date('d-m-Y')}}">
        </div>
   
{# 
        <div class="input-div">
                <label for="patient-dob">Ημ/νια Γεννήσεως</label>
                <input type="date" name="patient-dob" id="" role="date-picker" loader="info-loader" value="{{$patient->getpdob() | date('Y-m-d') }}">
            <!-- <input type="text" name="patient-dob" id="datepicker" value="{{$patient->getpdob()}}"> -->
        </div>
 #}
        <div class="input-div">
            <label for="patient-amka">ΑΜΚΑ</label>
            {# 
                <input type="text" name="patient-amka" loader="info-loader" validator="amka" value="{{$patient->getpamka()}}" placeholder="ΑΜΚΑ ασθενούς">
            #}
            <input type="text" name="patient-amka" loader="info-loader" validator="amka" value="{{$patient->getpamka()}}" placeholder="ΑΜΚΑ ασθενούς">
            
            <div class="inline-icons">
                <i class='valid bx bx-check' style='color:#00ff00'  ></i>
                <i class='not-valid bx bx-error' style='color:#ff0000'  ></i>
                
                <i class="bx bx-copy" data-copy-text="{{$patient->getpamka()}}" onclick0="copyStr0('{{$patient->getpamka()}}')"></i>
            </div>

            <!-- <img class="valid" src="data:image/png;base64,"/> -->
            <!-- <img class="not-valid" src="data:image/png;base64,"/> -->
        </div>

        <div class="input-div">
            <label for="patient-telephone">Τηλέφωνο</label>
            <input type="text" name="patient-telephone" loader="info-loader" validator="telephone" value="{{$patient->getptel()}}" placeholder="τηλέφωνο ασθενούς">

            <div class="inline-icons">
                <i class='valid bx bx-check' style='color:#00ff00'  ></i>
                <i class='not-valid bx bx-error' style='color:#ff0000'  ></i>
                
                <a href="tel:{{$patient->getptel()}}"><i class="bx bx-phone-call"></i></a>
                <i class="bx bx-copy" data-copy-text="{{$patient->getptel()}}"onclick="copyStr0('{{$patient->getptel()}}')"></i>
            </div>
        </div>

        <div class="input-div">
            <label for="patient-email">Email</label>
            <input type="text" name="patient-email" loader="info-loader" validator="email" value="{{$patient->getpemail()}}" placeholder="email ασθενούς">
            
                <div class="inline-icons">
                    <i class='valid bx bx-check' style='color:#00ff00'  ></i>
                    <i class='not-valid bx bx-error' style='color:#ff0000'  ></i>
                    
                    <i class="bx bx-copy" onclick="copyStr('{{$patient->getpemail()}}')"></i>
                </div>
        </div>

        <div class="input-div">
            <label for="patient-address">Διεύθυνση</label>
            <input type="text" name="patient-address" loader="info-loader" id=""  value="{{$patient->getpaddr()}}" placeholder="διεύθυνση ασθενούς">
        </div>

        <div class="input-div">
            <label for="patient-note">Σημειώσεις</label>
            <textarea name="patient-note" loader="info-loader" autoexpand id="" rows="5" placeholder="σημειώσεις">{{$patient->getpnote()}}</textarea>
        </div>
        <div class="buttons">
            <input type="submit" name="submit" value="Αποθήκευση">

            {% if($action == 'new'): %}
                <input type="submit" name="submitedit" value="Αποθήκευση & Επεξεργασία">
            {% else: %}
                <input type="submit" name="delete" value="Ακύρωση">
            {% endif %}

            <button hidden type="button" loader="info-loader" onclick="field_update(this)">Update</button>
            <div id="info-loader" class="loader0"></div>
        </div>
    </form>

    {% if($action != 'new'): %}
        <hr>
        <div class="patient-appointments">
            <div class="new-appointment">
                <a href="{{rel_url('/appointment/'.$id.'/newappointment')}}">Νέο Ραντεβού</a>
            </div>
        </div>
    {% endif %}

    {% if(isset($appointments) && (count($appointments)>0)): %}

        <div class="appointment-entries">

            <div class="appointment-dates">
                {% foreach($appdates as $ad): %}
                    <li>
                        <a href="#app-{{$ad['index']}}">
                            Date {{$ad['index']}}: {{$ad['date'] | date('d-m-Y')}}
                        </a>
                    </li>
                {% endforeach %}
            </div>            



            <ul class="patient-appointments-list">
                {% foreach($appointments as $ap): %}
                    <li data-index="{{$ap['index']}}">{{$ap['markup']}}</li>
                {% endforeach %}
            </ul`>
        </div>            


    {% endif %}
</div>

{#
<script>
    var picker = new Pikaday( { field: document.getElementById('datepicker') } );
</script>
#}

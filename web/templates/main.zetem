<!DOCTYPE html>
<html lang="en">

<head>
    {% if(isset($meta))foreach($meta as $metaline): %}
        <meta {{ $metaline }}>
    {% endforeach; %}

    {# check to see if there is title defined in yaml #}
    {% if(isset($head_title)): %}
        <title>{{ $head_title }}</title>
    {% endif %}


    {% if(isset($css))foreach($css as $css): %}
        <link rel="stylesheet" href="{{$css}}">
    {% endforeach %}

    {% if(isset($head_script))foreach($head_script as $scrpt): %}
        <script {{ $scrpt }}></script>
    {% endforeach; %}

</head>

<body>
    {% include page.zetem %}
</body>

    {% if(isset($foot_script))foreach($foot_script as $scrpt): %}
        <script {{ $scrpt }}></script>
    {% endforeach; %}

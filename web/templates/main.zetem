<!DOCTYPE html>
<html lang="en">

<head>
    {% global $info; %}
    {% foreach($info['meta'] as $meta): %}
        <meta {{ $meta }}>
    {% endforeach; %}

    {# check to see if there is title defined in yaml #}
    {% if(isset($info['title'])): %}
        <title>{{ $info['title'] }}</title>
    {% endif %}


    {% foreach($info['css'] as $css): %}
        <link rel="stylesheet" href="{{$css}}">
    {% endforeach %}

    {% foreach($info['script'] as $scrpt): %}
        <script {{ $scrpt }}></script>
    {% endforeach; %}

</head>

<body>
    {% include page.zetem %}
</body>

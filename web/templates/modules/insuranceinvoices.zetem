                <td><a href="{{rel_url('/apps/insuranceinvoices/'.$row->getid().'/view')}}" target="_blank"><i class="bx bx-show"></i></a>
                    <a href="{{rel_url('/apps/insuranceinvoices/'.$row->getid().'/delete')}}"><i class="bx bx-trash"></i></a>

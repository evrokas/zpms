{% attach_library('insuranceinvoices-library') %}

<h1>
    Insurance Invoices
</h1>

<p>
    Find here invoices from insurances
</p>

    <h2>Upload Doctor Fees PDF</h2>
    <form action="{{rel_url('/apps/insuranceinvoices/process')}}" method="post" enctype="multipart/form-data">
        <label>Select PDF: <input type="file" name="pdf" accept="application/pdf" required></label>
        <button type="submit">Upload and Parse</button>
    </form>

    <h2>Stored Records</h2>
    <table>
        <thead>
            <tr>
                <th>Patient</th>
                <th>Address</th>
                <th>Town</th>
                <th>Postal Code</th>
                <th>Amount</th>
                <th>Actions</th>
                {# <th>Copy</th> #}
            </tr>
        </thead>
        <tbody>
            <?php foreach($invoices as $row): ?>

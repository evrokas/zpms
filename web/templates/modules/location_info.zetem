{% attach_library('location-places') %}


<div class="location-place">
    {{t("Location")}}
    <select name="location" id="location-selector">
        {% foreach($location_places as $loc): %}
            <option value="{{$loc}}" {{ ($loc == $location)?"selected":""}}>{{$loc}}</option>
        {% endforeach %}
    </select>
</div>
